# ─── Application ───────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=        # generate: openssl rand -base64 32

# ─── Encryption (for API keys stored in DB) ────────────────────────────────────
ENCRYPTION_MASTER_KEY=  # generate: openssl rand -hex 32

# ─── Database (matches Docker Compose config) ──────────────────────────────────
DATABASE_URL=postgresql://mspdash:mspdash_secret@localhost:5432/mspdashboard

# ─── Seed admin user (Prisma seed script only) ────────────────────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=         # set a strong initial password
